#!/bin/env sh
# -*- mode:sh; coding:utf-8-unix; -*-

SCRIPT_DIR=$(realpath $(dirname $(readlink -f $0)))

source $SCRIPT_DIR/run_cargo.sh

OPTIONS="--all-targets --workspace"

function main() {
    run_cargo $ACTIVE_TOOLCHAIN check $OPTIONS || return $?
    run_cargo nightly fmt --check --all || return $?
    return 0
}

main || exit $?
exit 0
